name: Generate DRAFT Browser

on:
  push:
    branches:
      - main
    paths:
      - "**/*.yaml"
      - "configurations/browser/**"
      - ".draft/framework/browser/**"
      - ".draft/framework/tools/generate_browser.py"
      - ".draft/framework/docs/**"
      - "README.md"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  generate:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependency
        run: python -m pip install pyyaml

      - name: Generate browser
        run: python .draft/framework/tools/generate_browser.py --workspace . --output docs/index.html --refresh-shell

      - name: Commit generated browser
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add docs/index.html docs/assets docs/user-manual.html
          git diff --cached --quiet && exit 0
          git commit -m "chore: regenerate DRAFT browser [skip ci]"
          git push
